{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/members/src",
  "monorepo": true,
  "root": "apps/members",
  "compilerOptions": {
    "deleteOutDir": true,
    "tsConfigPath": "apps/members/tsconfig.app.json"
  },
  "projects": {
    "members": {
      "type": "application",
      "root": "apps/members",
      "entryFile": "main",
      "sourceRoot": "apps/members/src",
      "compilerOptions": {
        "tsConfigPath": "apps/members/tsconfig.app.json"
      }
    },
    "billing": {
      "type": "application",
      "root": "apps/billing",
      "entryFile": "main",
      "sourceRoot": "apps/billing/src",
      "compilerOptions": {
        "tsConfigPath": "apps/billing/tsconfig.app.json"
      }
    },
    "contracts": {
      "type": "library",
      "root": "libs/contracts",
      "entryFile": "index",
      "sourceRoot": "libs/contracts/src",
      "compilerOptions": {
        "tsConfigPath": "libs/contracts/tsconfig.lib.json"
      }
    },
    "access-control": {
      "type": "application",
      "root": "apps/access-control",
      "entryFile": "main",
      "sourceRoot": "apps/access-control/src",
      "compilerOptions": {
        "tsConfigPath": "apps/access-control/tsconfig.app.json"
      }
    }
  }
}